FLASK_ENV=development
FLASK_APP=run.py
JWT_SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=sqlite:///hostel_system.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
BOOTSTRAP_ADMIN_EMAIL=admin@hostel.com
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_HOSTEL=A
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
BOOTSTRAP_ADMIN_ON_START=false
BOOTSTRAP_ADMIN_FORCE_UPDATE=false
SEED_STUDENT_PASSWORD=change-this-student-password

# Production (Render) example:
# FLASK_ENV=production
# JWT_SECRET_KEY=<generate-secure-random-key>
# DATABASE_URL=<render-provides-this>
# CORS_ORIGINS=https://your-app.vercel.app
# BOOTSTRAP_ADMIN_EMAIL=admin@hostel.com
# BOOTSTRAP_ADMIN_NAME=System Admin
# BOOTSTRAP_ADMIN_HOSTEL=A
# BOOTSTRAP_ADMIN_PASSWORD=<set-in-render-env>
# BOOTSTRAP_ADMIN_ON_START=true
# BOOTSTRAP_ADMIN_FORCE_UPDATE=true  # true for one deploy to reset admin password, then set false
