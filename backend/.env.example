FLASK_ENV=development
FLASK_APP=run.py
JWT_SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=sqlite:///hostel_system.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_STUDENT_PASSWORD=change-this-student-password

# Production (Render) example:
# FLASK_ENV=production
# JWT_SECRET_KEY=<generate-secure-random-key>
# DATABASE_URL=<render-provides-this>
# CORS_ORIGINS=https://your-app.vercel.app
# SEED_ADMIN_PASSWORD=<set-in-render-env>
# SEED_STUDENT_PASSWORD=<set-in-render-env>
